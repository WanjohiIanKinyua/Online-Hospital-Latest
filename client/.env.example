REACT_APP_API_URL=http://localhost:5000

# For a single Vercel project, leave this blank in production so requests use /api.

# Jitsi video consultation.
# Public meet.jit.si works for testing, but production embedding should use Jitsi as a Service or a self-hosted Jitsi domain.
# REACT_APP_JITSI_DOMAIN=meet.jit.si
# Optional for Jitsi as a Service, where room names are prefixed by your app ID.
# REACT_APP_JITSI_APP_ID=your-jaas-app-id

# Optional but strongly recommended for production WebRTC video/audio.
# Use TURN credentials from a provider such as Metered, Twilio, Xirsys, or Cloudflare Calls.
# The app includes a public Open Relay fallback for testing, but production should use private TURN credentials.
# Example JSON shape:
# REACT_APP_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:your-turn-host:3478","turn:your-turn-host:443","turns:your-turn-host:443?transport=tcp"],"username":"your-turn-username","credential":"your-turn-password"}]
