PORT=5000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-vercel-domain.vercel.app

# Leave empty for local SQLite fallback. Set this in production for PostgreSQL/Neon.
DATABASE_URL=

# Optional email reset settings. Leave blank to use the local fallback reset code.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
